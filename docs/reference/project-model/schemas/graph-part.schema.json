{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threat-forge-llm.local/schemas/project-model/graph-part.schema.json",
  "title": "Graph Part Schema",
  "description": "Canonical shape contract for modular graph part files after YAML parsing.",
  "type": "object",
  "additionalProperties": false,
  "x-change_control": {
    "decided_by": [
      "schema-validation:DEC-0032"
    ],
    "satisfies": [
      "schema-validation:REQ-0041"
    ],
    "rationale": "This schema is introduced by the first schema-validation area extraction and is validated through the canonical format checker."
  },
  "x-applies_to": [
    "docs/reference/project-model/graph/cross-area.graph.yml",
    "docs/reference/project-model/graph/schema-validation.graph.yml",
    "docs/reference/project-model/graph/documentation-structure.graph.yml",
    "docs/reference/project-model/graph/markdown-format.graph.yml",
    "docs/reference/project-model/graph/requirements-governance.graph.yml",
    "docs/reference/project-model/graph/graph-traceability.graph.yml",
    "docs/reference/project-model/graph/source-traceability.graph.yml",
    "docs/reference/project-model/graph/governance-control.graph.yml",
    "docs/reference/project-model/graph/project-handoff.graph.yml",
    "docs/reference/project-model/graph/backend-architecture.graph.yml"
  ],
  "required": [
    "schema_version",
    "change_control",
    "schema_control",
    "part",
    "nodes",
    "triples"
  ],
  "properties": {
    "schema_version": {
      "$ref": "#/$defs/schemaVersion"
    },
    "change_control": {
      "$ref": "#/$defs/changeControl"
    },
    "schema_control": {
      "$ref": "#/$defs/schemaControl"
    },
    "part": {
      "$ref": "#/$defs/partMetadata"
    },
    "triples": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/triple"
      },
      "minItems": 1
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "textBlock": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "type": "string",
      "enum": [
        "1.0"
      ],
      "description": "Current governed graph matrix schema version. Future versions require explicit governance."
    },
    "requirementId": {
      "type": "string",
      "pattern": "^(?:[a-z][a-z0-9]*(?:-[a-z0-9]+)*:)?REQ-[0-9]{4}$",
      "description": "Root or canonical modular requirement ID reference."
    },
    "decisionId": {
      "type": "string",
      "pattern": "^(?:[a-z][a-z0-9]*(?:-[a-z0-9]+)*:)?DEC-[0-9]{4}$",
      "description": "Root or canonical modular decision ID reference."
    },
    "nodeTypeId": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$",
      "description": "Node type existence is semantic validation against governance.registry.yml node_types."
    },
    "predicateId": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "description": "Predicate existence and subject/object compatibility are semantic validation against governance.registry.yml predicates."
    },
    "entityId": {
      "type": "string",
      "minLength": 1,
      "description": "Entity IDs may be governed IDs or repository-relative artifact paths; existence is semantic validation."
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "description": "Repository-relative path. Filesystem existence is semantic validation."
    },
    "npmCommand": {
      "type": "string",
      "pattern": "^npm run [^\\s]+$",
      "description": "Current graph command nodes use npm run scripts. Script existence is semantic validation against package.json."
    },
    "changeControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decided_by",
        "satisfies",
        "rationale"
      ],
      "properties": {
        "decided_by": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/decisionId"
          },
          "uniqueItems": true
        },
        "satisfies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/requirementId"
          },
          "uniqueItems": true
        },
        "rationale": {
          "$ref": "#/$defs/textBlock"
        }
      }
    },
    "schemaControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "rationale"
      ],
      "properties": {
        "schema": {
          "const": "docs/reference/project-model/schemas/graph-part.schema.json"
        },
        "rationale": {
          "$ref": "#/$defs/textBlock"
        }
      },
      "description": "Declares the canonical schema that structurally validates this governed modular artifact."
    },
    "matrixMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "description"
      ],
      "properties": {
        "id": {
          "const": "project-graph-matrix"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "type": "string",
          "minLength": 1,
          "description": "Controlled by governance.registry.yml taxonomies.registry_status."
        },
        "description": {
          "$ref": "#/$defs/textBlock"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/entityId"
        },
        "type": {
          "$ref": "#/$defs/nodeTypeId"
        },
        "description": {
          "$ref": "#/$defs/textBlock"
        },
        "command": {
          "$ref": "#/$defs/npmCommand"
        },
        "path": {
          "$ref": "#/$defs/repositoryPath"
        }
      },
      "description": "A graph node declared directly by the matrix. Type-specific command/path requirements remain semantic validation."
    },
    "tripleEndpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/entityId"
        },
        "type": {
          "$ref": "#/$defs/nodeTypeId"
        }
      }
    },
    "triple": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subject",
        "predicate",
        "object"
      ],
      "properties": {
        "subject": {
          "$ref": "#/$defs/tripleEndpoint"
        },
        "predicate": {
          "$ref": "#/$defs/predicateId"
        },
        "object": {
          "$ref": "#/$defs/tripleEndpoint"
        }
      },
      "description": "A canonical Subject-Predicate-Object relationship. Predicate existence, type compatibility, duplicate detection, and entity existence remain semantic validation."
    },
    "projectModelAreaId": {
      "type": "string",
      "pattern": "^(global|[a-z][a-z0-9]*(?:-[a-z0-9]+)*)$"
    },
    "partDeclaration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "area_id",
        "path",
        "description"
      ],
      "properties": {
        "area_id": {
          "$ref": "#/$defs/projectModelAreaId"
        },
        "path": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/textBlock"
        }
      },
      "description": "Index entry for a modular project-model part. Area taxonomy membership and path consistency remain semantic validation."
    },
    "partMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "area_id",
        "title",
        "status",
        "description"
      ],
      "properties": {
        "area_id": {
          "$ref": "#/$defs/projectModelAreaId"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/textBlock"
        }
      }
    }
  }
}
