{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nballestriero.github.io/threat-forge-LLM/contracts/governance-control-report.schema.json",
  "title": "Governance Control Report",
  "description": "Machine-readable governance control report for threat-forge-LLM repository governance state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "repository",
    "checks",
    "documents",
    "requirements",
    "decisions",
    "capabilities",
    "commands",
    "tools",
    "gates",
    "graphs",
    "diagnostics"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "$ref": "#/$defs/repository"
    },
    "checks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/check"
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/document"
      }
    },
    "requirements": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/requirement"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/command"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entity"
      }
    },
    "graphs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "knowledge",
        "documentation",
        "file_relationships"
      ],
      "properties": {
        "knowledge": {
          "$ref": "#/$defs/graph"
        },
        "documentation": {
          "$ref": "#/$defs/graph"
        },
        "file_relationships": {
          "$ref": "#/$defs/graph"
        }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "branch": {
          "type": "string"
        },
        "head": {
          "type": "string"
        },
        "working_tree": {
          "type": "string",
          "enum": [
            "clean",
            "dirty",
            "unknown"
          ]
        }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pass",
            "fail",
            "not_run",
            "unknown"
          ]
        },
        "command": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "exit_code": {
          "type": "integer"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "stdout_excerpt": {
          "type": "string"
        },
        "stderr_excerpt": {
          "type": "string"
        }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "implementation_status": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "document": {
      "allOf": [
        {
          "$ref": "#/$defs/entity"
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "body_profile": {
              "type": "string"
            },
            "headings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "links_out": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "links_in": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      ]
    },
    "requirement": {
      "allOf": [
        {
          "$ref": "#/$defs/entity"
        },
        {
          "type": "object",
          "properties": {
            "macro_requirement_id": {
              "type": "string"
            },
            "priority": {
              "type": "string"
            },
            "verification_method": {
              "type": "string"
            },
            "links": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    },
    "command": {
      "allOf": [
        {
          "$ref": "#/$defs/entity"
        },
        {
          "type": "object",
          "properties": {
            "command": {
              "type": "string"
            }
          }
        }
      ]
    },
    "tool": {
      "allOf": [
        {
          "$ref": "#/$defs/entity"
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "type": "string"
            }
          }
        }
      ]
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nodes",
        "edges"
      ],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graph_node"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/graph_edge"
          }
        }
      }
    },
    "graph_node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      }
    },
    "graph_edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "predicate",
        "target"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "predicate": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string"
        },
        "target_type": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity",
        "code",
        "message"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "type"
          ],
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source"
          }
        },
        "suggested_action": {
          "type": "string"
        }
      }
    }
  }
}
